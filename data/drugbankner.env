# DrugBank credentials (used for HTTP basic auth download)
DRUGBANK_EMAIL="your@email"
DRUGBANK_PASSWORD="yourpassword"

# Optional: where to clone + run
WORKDIR="$HOME/work/drugbankner_run"

# Optional: node synonymizer fetch
# If you already have the sqlite, set NODE_SYNONYMIZER_LOCAL to its path and the script will copy it.
NODE_SYNONYMIZER_LOCAL=""

# Otherwise, provide the scp source (requires your SSH key already authorized on arax.databases.rtx.ai)
NODE_SYNONYMIZER_SCP_SRC="rtxconfig@arax-databases.rtx.ai:/home/rtxconfig/KG2.10.2/node_synonymizer_v1.0_KG2.10.2.sqlite"
